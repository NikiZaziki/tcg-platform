generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  username        String    @unique
  email           String    @unique
  passwordHash    String
  eloRating       Int       @default(1000)
  rankTier        String    @default("Bronze")
  createdAt       DateTime  @default(now())
  lastLogin       DateTime?
  lastDailyPack   DateTime?

  inventory       Inventory[]
  decks           Deck[]
  matchesAsPlayer1 Match[]  @relation("Player1")
  matchesAsPlayer2 Match[]  @relation("Player2")
  sentTrades      Trade[]   @relation("Sender")
  receivedTrades  Trade[]   @relation("Receiver")
  orders          Order[]
  packOpenings    PackOpening[]
  rankedTransfersWon   RankedTransfer[] @relation("Winner")
  rankedTransfersLost  RankedTransfer[] @relation("Loser")

  @@index([email])
  @@index([username])
}

model TCG {
  id              String    @id @default(uuid())
  name            String    @unique
  deckSize        Int
  maxCardCopies   Int
  rulesetVersion  String

  cards           Card[]
  packs           Pack[]
  decks           Deck[]
  matches         Match[]

  @@index([name])
}

model Card {
  id              String    @id @default(uuid())
  tcgId           String
  name            String
  rarity          String
  type            String
  attack          Int?
  defense         Int?
  abilityText     String?
  imageUrl        String

  tcg             TCG       @relation(fields: [tcgId], references: [id], onDelete: Cascade)
  inventory       Inventory[]
  deckCards       DeckCard[]
  packDropTables  PackDropTable[]
  packOpeningCards PackOpeningCard[]
  tradeCards      TradeCard[]
  rankedTransfers RankedTransfer[]

  @@index([tcgId])
  @@index([rarity])
  @@index([type])
}

model Rarity {
  id              String    @id @default(uuid())
  name            String    @unique
  dropRate        Float
  color           String

  packDropTables  PackDropTable[]

  @@index([name])
}

model Pack {
  id              String    @id @default(uuid())
  tcgId           String
  name            String
  price           Float
  cardsPerPack    Int
  packType        String

  tcg             TCG       @relation(fields: [tcgId], references: [id], onDelete: Cascade)
  dropTables      PackDropTable[]
  orderItems      OrderItem[]
  packOpenings    PackOpening[]

  @@index([tcgId])
  @@index([packType])
}

model PackDropTable {
  id              String    @id @default(uuid())
  packId          String
  rarityId        String
  probability     Float

  pack            Pack      @relation(fields: [packId], references: [id], onDelete: Cascade)
  rarity          Rarity    @relation(fields: [rarityId], references: [id], onDelete: Cascade)
  card            Card      @relation(fields: [rarityId], references: [id], onDelete: Cascade)

  @@unique([packId, rarityId])
  @@index([packId])
  @@index([rarityId])
}

model Inventory {
  id              String    @id @default(uuid())
  userId          String
  cardId          String
  quantity        Int       @default(0)
  obtainedAt      DateTime  @default(now())
  source          String

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  card            Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId])
  @@index([cardId])
}

model Deck {
  id              String    @id @default(uuid())
  userId          String
  tcgId           String
  name            String
  createdAt       DateTime  @default(now())
  lastUsed        DateTime?

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tcg             TCG       @relation(fields: [tcgId], references: [id], onDelete: Cascade)
  cards           DeckCard[]
  matchesAsDeck1   Match[]   @relation("Deck1")
  matchesAsDeck2  Match[]   @relation("Deck2")

  @@index([userId])
  @@index([tcgId])
}

model DeckCard {
  id              String    @id @default(uuid())
  deckId          String
  cardId          String
  quantity        Int       @default(0)

  deck            Deck      @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card            Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([deckId, cardId])
  @@index([deckId])
  @@index([cardId])
}

model Match {
  id              String    @id @default(uuid())
  player1Id       String
  player2Id       String
  deck1Id         String
  deck2Id         String
  mode            String
  status          String
  winnerId        String?
  createdAt       DateTime  @default(now())
  endedAt         DateTime?

  player1         User      @relation("Player1", fields: [player1Id], references: [id])
  player2         User      @relation("Player2", fields: [player2Id], references: [id])
  deck1           Deck      @relation("Deck1", fields: [deck1Id], references: [id])
  deck2           Deck      @relation("Deck2", fields: [deck2Id], references: [id])
  rankedTransfers RankedTransfer[]

  @@index([player1Id])
  @@index([player2Id])
  @@index([status])
  @@index([mode])
  @@index([createdAt])
}

model RankedTransfer {
  id              String    @id @default(uuid())
  matchId         String
  winnerId        String
  loserId         String
  cardId          String
  timestamp       DateTime  @default(now())

  match           Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  winner          User      @relation("Winner", fields: [winnerId], references: [id])
  loser           User      @relation("Loser", fields: [loserId], references: [id])
  card            Card      @relation(fields: [cardId], references: [id])

  @@index([matchId])
  @@index([winnerId])
  @@index([loserId])
  @@index([timestamp])
}

model PackOpening {
  id              String    @id @default(uuid())
  userId          String
  packId          String
  openedAt        DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pack            Pack      @relation(fields: [packId], references: [id], onDelete: Cascade)
  cards           PackOpeningCard[]

  @@index([userId])
  @@index([packId])
  @@index([openedAt])
}

model PackOpeningCard {
  id              String    @id @default(uuid())
  openingId       String
  cardId          String

  opening         PackOpening @relation(fields: [openingId], references: [id], onDelete: Cascade)
  card            Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([openingId])
  @@index([cardId])
}

model Order {
  id              String    @id @default(uuid())
  userId          String
  totalPrice      Float
  status          String
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id              String    @id @default(uuid())
  orderId         String
  packId          String
  quantity        Int
  price           Float

  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pack            Pack      @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([packId])
}

model Trade {
  id              String    @id @default(uuid())
  senderId        String
  receiverId      String
  status          String
  createdAt       DateTime  @default(now())

  sender          User      @relation("Sender", fields: [senderId], references: [id])
  receiver        User      @relation("Receiver", fields: [receiverId], references: [id])
  cards           TradeCard[]

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([createdAt])
}

model TradeCard {
  id              String    @id @default(uuid())
  tradeId         String
  userId          String
  cardId          String
  quantity        Int

  trade           Trade     @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  card            Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@index([userId])
  @@index([cardId])
}
